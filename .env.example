# ============================================================
# CONFIGURAZIONE FIREBASE - File di esempio
# ============================================================
# Copiare questo file in `.env` (senza .example) e compilare
# con i propri valori dalla console Firebase.
#
# IMPORTANTE: Il file `.env` NON deve mai essere caricato
# su GitHub (è già in .gitignore).
#
# Per ottenere questi valori:
# 1. Andare su https://console.firebase.google.com/
# 2. Selezionare il progetto BoatBooking
# 3. Icona ingranaggio -> Impostazioni progetto
# 4. Scorrere fino a "Le tue app" -> selezionare l'app web
# 5. Copiare i valori dalla sezione "SDK setup and configuration"
# ============================================================

REACT_APP_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
REACT_APP_FIREBASE_AUTH_DOMAIN=boatbooking-XXXXX.firebaseapp.com
REACT_APP_FIREBASE_DATABASE_URL=https://boatbooking-XXXXX-default-rtdb.europe-west1.firebasedatabase.app
REACT_APP_FIREBASE_PROJECT_ID=boatbooking-XXXXX
REACT_APP_FIREBASE_STORAGE_BUCKET=boatbooking-XXXXX.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789012
REACT_APP_FIREBASE_APP_ID=1:123456789012:web:abcdef0123456789

# ============================================================
# CONFIGURAZIONE EMAILJS - Notifiche email su nuova prenotazione
# ============================================================
# Per ottenere questi valori:
# 1. Andare su https://dashboard.emailjs.com/
# 2. Email Services -> Service ID
# 3. Email Templates -> Template ID
# 4. Account -> General -> Public Key
# ============================================================

REACT_APP_EMAILJS_SERVICE_ID=service_xxxxxxx
REACT_APP_EMAILJS_TEMPLATE_ID=template_xxxxxxx
REACT_APP_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxx
