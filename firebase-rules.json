{
  "rules": {
    "authorized_users": {
      ".read": "auth != null",
      ".write": false
    },

    "notification_recipients": {
      ".read": "auth != null && root.child('authorized_users').child(auth.uid).val() === true",
      ".write": false,

      "$entryId": {
        ".validate": "newData.hasChildren(['email', 'name'])",
        "email": {
          ".validate": "newData.isString() && newData.val().matches(/^[^@]+@[^@]+\\.[^@]+$/)"
        },
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
        },
        "$other": {
          ".validate": false
        }
      }
    },

    "bookings": {
      ".read": "auth != null && root.child('authorized_users').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('authorized_users').child(auth.uid).val() === true",

      ".indexOn": ["startDate", "endDate", "userId"],

      "$bookingId": {
        ".validate": "newData.hasChildren(['startDate', 'endDate', 'userId', 'userName', 'createdAt'])",

        ".write": "auth != null && root.child('authorized_users').child(auth.uid).val() === true && (!data.exists() || data.child('userId').val() === auth.uid)",

        "userId": {
          ".validate": "newData.val() === auth.uid"
        },
        "userName": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
        },
        "startDate": {
          ".validate": "newData.isString() && newData.val().matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/)"
        },
        "endDate": {
          ".validate": "newData.isString() && newData.val().matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/) && newData.val() >= newData.parent().child('startDate').val()"
        },
        "notes": {
          ".validate": "newData.isString() && newData.val().length <= 200"
        },
        "createdAt": {
          ".validate": "newData.isString()"
        },
        "boatId": {
          ".validate": "newData.isString() && (newData.val() === 'barca' || newData.val() === 'gommone')"
        },
        "$other": {
          ".validate": false
        }
      }
    }
  }
}
